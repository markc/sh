# Service control wrapper
if [[ ${OSTYP:-} == openwrt ]]; then
    sc() {
        local service_name="$2"

        # Handle common actions
        case "$1" in
        enable)
            $SUDO /etc/init.d/"$service_name" enable
            ;;
        disable)
            $SUDO /etc/init.d/"$service_name" disable
            ;;
        status)
            $SUDO /etc/init.d/"$service_name" status
            ;;
        restart)
            $SUDO /etc/init.d/"$service_name" restart
            ;;
        reload)
            $SUDO /etc/init.d/"$service_name" reload
            ;;
        start)
            $SUDO /etc/init.d/"$service_name" start
            ;;
        stop)
            $SUDO /etc/init.d/"$service_name" stop
            ;;
        *)
            # List all available init scripts
            ls -1 /etc/init.d/ | grep -v '^README'
            ;;
        esac
    }

    function getent {
        if [[ $1 == passwd ]]; then
            cat /etc/passwd
        elif [[ $1 == group ]]; then
            cat /etc/group
        fi
    }
    #export -f getent  # Disabled to prevent systemd warnings
elif [[ ${OSTYP:-} == alpine ]]; then
    sc() {
        # Convert systemd-style service@instance to OpenRC service.instance
        local service_name="$2"
        if [[ "$2" == *"@"* ]]; then
            service_name="${2/@/.}"
        fi

        # Handle common actions
        case "$1" in
        enable)
            $SUDO rc-update add "$service_name" default
            ;;
        disable)
            $SUDO rc-update del "$service_name" default
            ;;
        status)
            $SUDO rc-service "$service_name" status
            ;;
        restart)
            $SUDO rc-service "$service_name" restart
            ;;
        reload)
            $SUDO rc-service "$service_name" reload
            ;;
        start)
            $SUDO rc-service "$service_name" start
            ;;
        stop)
            $SUDO rc-service "$service_name" stop
            ;;
        *)
            $SUDO rc-status --all | awk '/\[.*\]/ {print $1}'
            ;;
        esac
    }
else
    sc() {
        if [[ -z $1 ]]; then
            $SUDO systemctl list-units --type=service | awk 'NR>1 {sub(".service", "", $1); print $1}' | head -n -7
        else
            $SUDO systemctl $1 $2
        fi
    }
fi

