# Mark this as a Netserva script
export NSENV=1

# Source the main shell configuration
. ~/.shrc

[[ $1 =~ -h ]] && echo "Usage: shpwtxt" && exit 1

find /home/u/*/var/www -maxdepth 1 -regex ".*/[0-9][0-9][0-9][0-9].txt"

systemd-cat -t hlog echo "$(whoami) $(basename $0) $*"
