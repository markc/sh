# Mark this as a Netserva script
export NSENV=1

# Source the main shell configuration
. ~/.shrc

[[ -z $2 || $1 =~ '-h' ]] && echo "Usage: addvalias source target" && exit 1

[[ $(id -u) -gt 0 ]] && echo "ERROR: must be root (use sudo -i)" && exit 2

FMAIL=${1,,}      # lowercase source
TMAIL=${2,,}      # lowercase target
VHOST=${TMAIL#*@} # userid @ $VHOST

source /root/.vhosts/$VHOST || exit 3

[[ $DEBUG ]] && set -x

V_CREATED=$(date +"%Y-%m-%d %H:%M:%S")

HID=$(
    cat <<EOS | $SQCMD
 SELECT id
   FROM vhosts
  WHERE domain = '$VHOST'
EOS
)

[[ -z $HID ]] && echo "ERROR: '$VHOST' does not exist in $ADMIN.vhosts" && exit 3

USRID=$(
    cat <<EOS | $SQCMD
 SELECT id
   FROM valias
  WHERE source = '$FMAIL'
EOS
)

[[ $USRID ]] && echo "ERROR: '$FMAIL' already exists in $ADMIN.valias" && exit 4

cat <<EOS | $SQCMD
 INSERT INTO valias (
        hid,
        source,
        target,
        updated,
        created
) VALUES (
        $HID,
        '$FMAIL',
        '$TMAIL',
        '$V_CREATED',
        '$V_CREATED'
)
EOS

shalias $FMAIL

[[ $DEBUG ]] && set +x
