# Mark this as a Netserva script
export NSENV=1

# Source the main shell configuration
. ~/.shrc

[[ -z $1 || $1 =~ '-h' ]] && echo "Usage: shdu domain|email" && exit 1

[[ $DEBUG ]] && set -x

if [[ $1 =~ @ ]]; then
    dir="/home/u/${1#*@}/home/${1%@*}"
    if [[ -d "$dir" ]]; then
        du -sh "$dir"
    else
        echo "No such user: $1"
    fi
else
    dir="/home/u/$1"
    if [[ -d "$dir" ]]; then
        du -sh "$dir"
    else
        echo "No such domain: $1"
    fi
fi

[[ $DEBUG ]] && set +x
