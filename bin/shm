# Mark this as a Netserva script
export NSENV=1

# Source the main shell configuration
. ~/.shrc

# Mark this as a Netserva script
export NSENV=1

# Source the main shell configuration
. ~/.shrc

[[ -z $REPO ]] && REPO=~/.sh

usage() {
    echo "\
cd
$REPO/bin/shm install
shm [install|pull|push|remove|removeall|perms]"
}

sh_perms() {
    chmod 700 $REPO $REPO/{bin,etc,lib}
    chmod 700 $REPO/bin/*
    chmod 600 $REPO/{LICENSE.md,README.md,_help,_myrc,_shrc,etc/*,lib/*}
}

sh_install() {
    local F FF DF
    cd
    for F in $(ls -1 $REPO/_*); do
        FF=$(basename $F)
        DF=".${FF#_}"
        if [[ ! -f $HOME/$DF ]]; then
            [[ $DF = ".myrc" ]] && cp $F $DF || ln -s $(basename $REPO)/$FF $DF
        fi
    done
    sh_perms
    [ -f ~/.profile ] && sed -i 's/^mesg/#mesg/' ~/.profile
    touch ~/.hushlogin
    echo "[ -f /etc/profile ] && . /etc/profile" >>~/.bashrc
    echo "[ -f ~/.shrc ] && . ~/.shrc" >>~/.bashrc
}

sh_remove() {
    local F FF DF
    cd
    sed -i '/\.shrc/d' ~/.bashrc
    for F in $(ls -1 $REPO/_*); do
        FF=$(basename $F)
        DF=".${FF#_}"
        if [[ -L $DF ]]; then
            [[ $DF != ".myrc" ]] && rm -v $DF
        fi
    done
}

sh_remove_all() {
    sh_remove
    [[ -f ~/.myrc ]] && cp -v ~/.myrc ~/.myrc.bkp
    cd
    rm -rf $REPO
    echo "
### To reinstall this repo use...
cd && git clone https://github.com/markc/sh .sh
$REPO/bin/shm install
. ~/.shrc
"
}

case "$1" in
install)
    sh_install
    ;;
diff)
    cd "$REPO"
    git diff HEAD@{1}
    ;;
pull)
    cd "$REPO"
    git pull
    ;;
push)
    cd "$REPO"
    git commit -a
    git push
    ;;
remove)
    sh_remove
    ;;
removeall)
    sh_remove_all
    ;;
perms)
    sh_perms
    ;;
*)
    usage
    ;;
esac

[[ $DEBUG ]] && set +x
