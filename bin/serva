# Check if at least two arguments are passed
if [[ $# -lt 2 || $1 == '-h' ]]; then
    echo "Usage: $0 start|stop|enable|disable|restart|reload <service_name|all>"
    exit 1
fi

# Assign the arguments to variables
ACTION=$1
SERVICE=$2

# List of services to manage when 'all' is specified
SERVICES=(
  "cron"
  "dovecot"
  "mailgraph"
  "mariadb"
  "multipathd"
  "nginx"
  "opendkim"
  "opendmarc"
  "pdns"
  "php8.1-fpm"
  "php8.2-fpm"
  "php8.3-fpm"
  "postfix"
  "redis-server"
  "rsyslog"
  "sshguard"
  "vnstat"
)

# Function to perform an action on a service
manage_service() {
    local service=$1
    case $ACTION in
        start|stop|restart|reload)
            echo "${ACTION^}ing service '$service'..."
            sudo systemctl $ACTION $service
            ;;
        enable|disable)
            if sudo systemctl is-enabled --quiet $service; then
                [[ $ACTION == "enable" ]] && echo "Service '$service' is already enabled." && return
            else
                [[ $ACTION == "disable" ]] && echo "Service '$service' is already disabled." && return
            fi
            echo "${ACTION^}ing service '$service'..."
            sudo systemctl $ACTION $service
            ;;
        *)
            echo "Invalid action: $ACTION"
            exit 1
            ;;
    esac

    # Verify action result
    if [[ $? -eq 0 ]]; then
        echo "Service '$service' ${ACTION}ed successfully."
    else
        echo "Failed to ${ACTION} service '$service'."
    fi
}

# Main script logic
if [[ $SERVICE == "all" ]]; then
    for svc in "${SERVICES[@]}"; do
        manage_service "$svc"
    done
else
    manage_service "$SERVICE"
fi
