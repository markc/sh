# Check for required parameters
if [ "$#" -lt 3 ]; then
    echo "Usage: addncuser domain username password [display_name] [email] [group]"
    exit 1
fi

[[ $DEBUG ]] && set -x

DOMAIN=$1
USERNAME=$2
PASSWORD=$3
DISPLAY_NAME=${4:-"$USERNAME"}
EMAIL=${5:-""}
GROUP=${6:-""}
NCUSER=u1002

# Path to Nextcloud installation
NC_PATH="/home/u/$DOMAIN/var/www/html"

# Build the command with proper argument handling
CMD="sudo -u $NCUSER php $NC_PATH/occ user:add"

if [ ! -z "$DISPLAY_NAME" ]; then
    CMD="$CMD --display-name '$DISPLAY_NAME'"
fi

if [ ! -z "$EMAIL" ]; then
    CMD="$CMD --email '$EMAIL'"
fi

if [ ! -z "$GROUP" ]; then
    CMD="$CMD --group '$GROUP'"
fi

CMD="$CMD --password-from-env $USERNAME"

# Create user with password
export OC_PASS="$PASSWORD"
eval $CMD
RESULT=$?
unset OC_PASS

if [ $RESULT -eq 0 ]; then
    echo "User $USERNAME created successfully"
else
    echo "Failed to create user $USERNAME"
    exit 1
fi

[[ $DEBUG ]] && set +x
