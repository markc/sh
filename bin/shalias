[[ -z $1 || $1 =~ '-h' ]] && echo "Usage: shalias [%]email" && exit 1

source /root/.vhosts/$(hostname -f) || exit 2 # only needed for SQCMD

[[ $DEBUG ]] && set -x

PWTBL=valias

echo "
 SELECT source,target
   FROM $PWTBL
  WHERE source LIKE '$1%'
  ORDER BY source" | $SQCMD

[[ $DEBUG ]] && set -x
