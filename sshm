# sshm — SSH Manager
#
# Single tool to bootstrap, configure, and deploy the ~/.sh shell toolkit.
# Manages three things:
#   1. Shell config — init bash profile/rc files, personal ~/.myrc
#   2. SSH hosts    — save servers by nickname, connect with: ssh nickname
#   3. SSH keys     — create/manage Ed25519 keypairs for passwordless login
#
# Quick start:
#   sshm init                        # Set up this machine (shell + SSH)
#   sshm create myserver 10.0.0.5    # Save a server
#   ssh myserver                    # Connect!
#   sshm sync myserver               # Deploy ~/.sh to that server
#
# All commands: sshm ha

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[[ -f "$DIR/_shrc" ]] && source "$DIR/_shrc"

help() {
    case $1 in
    a | all)
        cat <<'EOF'
SSHM — SSH Manager
==================
Bootstrap, configure, and deploy the ~/.sh shell toolkit.

SETUP
  sshm init                                         # Set up this machine (shell + SSH)
  sshm sync HOST                                    # Deploy ~/.sh to remote + run init

  init creates (if missing):
    ~/.bash_profile    from ~/.sh/_bash_profile
    ~/.bashrc          from ~/.sh/_bashrc
    ~/.myrc            from ~/.sh/_myrc.example
    ~/.ssh/            NetServa 3.0 structure (hosts/, keys/, mux/, config)

  sync rsyncs ~/.sh/ (excluding .git) to HOST, then runs sshm init remotely.
  ~/.myrc is never synced — each machine keeps its own.

HOST COMMANDS — save servers by nickname
  create NAME IP [PORT] [USER] [KEYFILE]           # Save host (defaults: 22, root, ~/.ssh/keys/default)
  list                                             # Show all saved hosts
  read NAME                                        # Show host config values
  update NAME                                      # Edit host config in nano
  delete NAME                                      # Remove host
  test [NAME] [--delete-failed]                    # Test SSH connectivity

  Examples:
    sshm create web 10.0.0.5                        # Basic — port 22, user root, default key
    sshm create db 10.0.0.6 2222 admin              # Custom port and user
    sshm create pi 192.168.1.50 22 pi ~/k/pi        # With specific key
    sshm test                                       # Test all hosts
    sshm test --delete-failed                       # Test all, remove dead ones

KEY COMMANDS — Ed25519 keypairs for passwordless login
  key_create [NAME] [COMMENT] [PASSPHRASE]         # Create keypair (default name: "default")
  key_list                                         # Show all keys with fingerprints
  key_read [NAME]                                  # Show public key (default name: "default")
  key_delete NAME                                  # Remove keypair

  Examples:
    sshm key_create                                 # Create default key (no passphrase)
    sshm key_create work "Laptop" "secret"          # Named key with comment and passphrase
    ssh-copy-id -i ~/.ssh/keys/default.pub u@server  # Deploy key to server

GIT — update and publish ~/.sh
  pull                                             # Fetch upstream, pull if newer
  push [MESSAGE]                                   # Commit all changes + push

  Examples:
    sshm pull                                       # Check for updates
    sshm push                                       # Commit + push (auto message)
    sshm push "Add custom aliases"                  # Commit + push with message

UTILITIES
  sshm perms                                        # Fix ~/.ssh permissions (after rsync)

SERVICE (sudo required)
  sshm start                                        # Start sshd (no auto-boot)
  sshm stop                                         # Stop sshd, disable, drop INCOMING

SHORTCUTS
  i=init  s=sync                                   # Setup
  c=create  r=read  u=update  d=delete             # Hosts
  l=list  t=test  p=perms                          # Hosts/utils
  kc=key_create  kr=key_read  kd=key_delete  kl=key_list  # Keys
  pull  push                                       # Git
  h=help  ha=help all                              # Help

FILES
  ~/.sh/_shrc         Core shell toolkit (sourced by ~/.bashrc)
  ~/.sh/_shrc.d/      Optional server modules (loaded via ~/.myrc)
  ~/.myrc             Personal config (machine-local, never synced)
  ~/.ssh/hosts/*      Individual SSH host configs
  ~/.ssh/keys/*       Ed25519 keypairs
  ~/.ssh/mux/*        ControlMaster multiplexing sockets
EOF
        ;;
    i | init)
        echo "Initialize this machine: shell config + SSH structure"
        echo "Usage: sshm init"
        echo "  Creates ~/.bash_profile, ~/.bashrc, ~/.myrc from templates"
        echo "  Creates ~/.ssh/ with hosts/, keys/, mux/, config"
        echo "  Safe to run multiple times (idempotent)"
        ;;
    s | sync)
        echo "Deploy ~/.sh to a remote server"
        echo "Usage: sshm sync <host>"
        echo "  Rsyncs ~/.sh/ (excluding .git) then runs sshm init remotely"
        echo "  ~/.myrc is never synced — each machine keeps its own"
        ;;
    c | create)
        echo "Save an SSH host by nickname"
        echo "Usage: sshm create <name> <ip> [port] [user] [keyfile]"
        echo "  Defaults: port 22, user root, key ~/.ssh/keys/default"
        echo "  Creates ~/.ssh/hosts/<name>"
        ;;
    r | read | show)
        echo "Show saved host config values"
        echo "Usage: sshm read <name>"
        ;;
    u | update)
        echo "Edit a host config in nano"
        echo "Usage: sshm update <name>"
        ;;
    d | delete)
        echo "Remove a saved host"
        echo "Usage: sshm delete <name>"
        ;;
    l | list)
        echo "List all saved hosts with connection details"
        echo "Usage: sshm list"
        ;;
    t | test)
        echo "Test SSH connectivity"
        echo "Usage: sshm test [name] [--delete-failed]"
        echo "  No args: test all hosts"
        echo "  With name: test one host"
        echo "  --delete-failed: remove unreachable hosts (not ephemeral)"
        ;;
    kc | key_create)
        echo "Create an Ed25519 keypair"
        echo "Usage: sshm key_create [name] [comment] [passphrase]"
        echo "  Default name: 'default' — used by host create when no key specified"
        echo "  Keys stored in ~/.ssh/keys/, 100 KDF rounds"
        ;;
    kr | key_read)
        echo "Show a public key (for copying to servers)"
        echo "Usage: sshm key_read [name]  (default: 'default')"
        ;;
    kd | key_delete)
        echo "Remove a keypair (private + public)"
        echo "Usage: sshm key_delete <name>"
        ;;
    kl | key_list)
        echo "List all keys with fingerprints"
        echo "Usage: sshm key_list"
        ;;
    pull)
        echo "Check upstream for updates and pull if available"
        echo "Usage: sshm pull"
        echo "  Fetches from origin, shows status, pulls if behind"
        ;;
    push)
        echo "Commit all changes and push to upstream"
        echo "Usage: sshm push [message]"
        echo "  Without message: auto-generates from changed files"
        echo "  With message: uses your message as commit summary"
        ;;
    p | perms)
        echo "Fix ~/.ssh permissions (directories 700, files 600)"
        echo "Usage: sshm perms"
        echo "  Use after git clone or rsync"
        ;;
    start)
        echo "Start SSH daemon without enabling at boot (sudo)"
        echo "Usage: sshm start"
        ;;
    stop)
        echo "Stop SSH daemon, disable at boot, drop INCOMING connections (sudo)"
        echo "Usage: sshm stop"
        ;;
    *)
        cat <<'EOF'
Usage: sshm <command> [args]

  SETUP        i  = init        s  = sync
  HOSTS        c  = create      r  = read       u = update
               d  = delete      l  = list        t = test
  KEYS         kc = key_create  kr = key_read
               kd = key_delete  kl = key_list
  GIT          pull             push
  UTILS        p  = perms       start            stop
  HELP         h  = help        ha = help all

Quick start:  sshm init && sshm create myserver 10.0.0.5 && ssh myserver
Full help:    sshm ha
EOF
        ;;
    esac
}

[[ -z $1 || $1 =~ -h ]] && help && exit 1

# ========== SHELL INIT ==========

shell_init() {
    # Create ~/.bash_profile from template if missing
    if [[ ! -f ~/.bash_profile ]]; then
        if [[ -f ~/.sh/_bash_profile ]]; then
            cp ~/.sh/_bash_profile ~/.bash_profile
            echo "✅ Created ~/.bash_profile"
        else
            echo "⚠️  Template ~/.sh/_bash_profile not found"
        fi
    else
        echo "ℹ️  ~/.bash_profile already exists"
    fi

    # Create ~/.bashrc from template if missing
    if [[ ! -f ~/.bashrc ]]; then
        if [[ -f ~/.sh/_bashrc ]]; then
            cp ~/.sh/_bashrc ~/.bashrc
            echo "✅ Created ~/.bashrc"
        else
            echo "⚠️  Template ~/.sh/_bashrc not found"
        fi
    else
        # Ensure existing .bashrc sources ~/.sh/_shrc
        local source_line='[[ -f ~/.sh/_shrc ]] && source ~/.sh/_shrc'
        if ! grep -qF "$source_line" ~/.bashrc; then
            echo "" >> ~/.bashrc
            echo "# Source SH shell enhancements" >> ~/.bashrc
            echo "$source_line" >> ~/.bashrc
            echo "✅ Added sourcing line to ~/.bashrc"
        else
            echo "ℹ️  ~/.bashrc already sources ~/.sh/_shrc"
        fi
    fi

    # Create user customization file from template if missing
    if [[ ! -f ~/.myrc ]]; then
        if [[ -f ~/.sh/_myrc.example ]]; then
            cp ~/.sh/_myrc.example ~/.myrc
            echo "✅ Created ~/.myrc from template"
            echo "ℹ️  Edit ~/.myrc to add your personal customizations"
        else
            echo "⚠️  Template ~/.sh/_myrc.example not found"
        fi
    else
        echo "ℹ️  ~/.myrc already exists"
    fi
}

# ========== SSH INIT ==========

ssh_init() {
    [[ -d ~/.ssh ]] || { mkdir ~/.ssh && chmod 700 ~/.ssh && echo "Created ~/.ssh"; }
    [[ -f ~/.ssh/authorized_keys ]] || { touch ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys && echo "Created ~/.ssh/authorized_keys"; }
    [[ -d ~/.ssh/hosts ]] || { mkdir ~/.ssh/hosts && chmod 700 ~/.ssh/hosts && echo "Created ~/.ssh/hosts"; }
    [[ -d ~/.ssh/keys ]] || { mkdir ~/.ssh/keys && chmod 700 ~/.ssh/keys && echo "Created ~/.ssh/keys"; }
    [[ -d ~/.ssh/mux ]] || { mkdir ~/.ssh/mux && chmod 700 ~/.ssh/mux && echo "Created ~/.ssh/mux (for ControlMaster sockets)"; }

    [[ -f ~/.ssh/config ]] || {
        echo "# SSH Configuration
# Created by sshm on $(date +'%Y%m%d')

# Security and Performance
Ciphers aes128-ctr,aes192-ctr,aes256-ctr,aes128-gcm@openssh.com,aes256-gcm@openssh.com,chacha20-poly1305@openssh.com

# Include all host configurations from ~/.ssh/hosts/
Include ~/.ssh/hosts/*

# Global defaults for all hosts
Host *
  TCPKeepAlive yes
  ServerAliveInterval 30
  ForwardAgent yes
  AddKeysToAgent yes
  IdentitiesOnly yes
  # ControlMaster for connection multiplexing
  ControlMaster auto
  ControlPath ~/.ssh/mux/%r@%h:%p
  ControlPersist 10m" >~/.ssh/config
    }
    perms
}

# ========== COMBINED INIT ==========

init() {
    shell_init
    echo ""
    ssh_init
    echo ""
    echo "✅ SH initialized (shell + SSH)"
}

# ========== SYNC ==========

sync() {
    local ssh_host="$1"

    if [[ -z "$ssh_host" ]]; then
        echo "❌ Error: SSH host required"
        echo "Usage: sshm sync <ssh_host>"
        exit 1
    fi

    if ! grep -q "^Host $ssh_host$" ~/.ssh/hosts/* 2>/dev/null; then
        echo "⚠️  Warning: SSH host '$ssh_host' not found in ~/.ssh/hosts/"
        echo "Attempting connection anyway..."
    fi

    echo "🔄 Syncing ~/.sh/ to $ssh_host:~/.sh/..."
    rsync -avz --exclude='.git' ~/.sh/ "$ssh_host":~/.sh/

    if [[ $? -eq 0 ]]; then
        echo "✅ Sync completed"
        echo "🔧 Running init on $ssh_host..."
        ssh "$ssh_host" "~/.sh/sshm init"
    else
        echo "❌ Sync failed"
        exit 1
    fi
}

# ========== HOST COMMANDS ==========

create() {
    local name=$1 host=$2 port=${3:-22} user=${4:-root} skey=${5:-'~/.ssh/keys/default'}

    echo "Host $name
  Hostname $host
  Port $port
  User $user
  IdentityFile $skey" >~/.ssh/hosts/$name
}

show() {
    local name=$1
    if [[ -f ~/.ssh/hosts/$name ]]; then
        awk '{print $2}' ~/.ssh/hosts/$name
    else
        echo "Notice: ~/.ssh/hosts/'$name' does not exist"
        exit 254
    fi
}

update() {
    local name=$1
    if [[ -f ~/.ssh/hosts/$name ]]; then
        nano -t -x -c ~/.ssh/hosts/$name
    else
        echo "Notice: ~/.ssh/hosts/'$name' does not exist"
        exit 254
    fi
}

delete() {
    local name=$1
    if [[ -f ~/.ssh/hosts/$name ]]; then
        rm ~/.ssh/hosts/$name
        echo "Removed: SSH host '$name'"
    else
        echo "Error: SSH host '$name' does not exist"
        exit 255
    fi
}

list() {
    for file in ~/.ssh/hosts/*; do
        [[ -f "$file" ]] || continue
        awk '
        BEGIN { host=""; hostname=""; port="22"; user="root"; key="" }
        /^Host / { host=$2 }
        /Hostname/ { hostname=$2 }
        /Port/ { port=$2 }
        /User/ { user=$2 }
        /IdentityFile/ { key=$2 }
        END { printf "%-15s %17s %5s %10s %25s\n", host, hostname, port, user, key }
        ' "$file"
    done
}

# ========== KEY COMMANDS ==========

key_create() {
    local name=${1:-default} comment=${2:-"$(hostname)@lan"} password=${3:-""}

    if [[ -f ~/.ssh/keys/$name ]]; then
        echo "Warning: SSH Key '~/.ssh/keys/$name' already exists"
        exit 254
    fi

    if ! ssh-keygen -o -a 100 -t ed25519 -f ~/.ssh/keys/$name -C "$comment" -N "$password"; then
        echo "Error: SSH key '$name' not created"
        exit 254
    fi
}

key_read() {
    local name=${1:-default}
    if [[ -f ~/.ssh/keys/$name.pub ]]; then
        cat ~/.ssh/keys/$name.pub
    else
        echo "Warning: '$name' key does not exist"
        exit 254
    fi
}

key_delete() {
    local name=$1
    if [[ -f ~/.ssh/keys/$name ]]; then
        rm ~/.ssh/keys/$name ~/.ssh/keys/$name.pub
        echo "Success: removed ~/.ssh/keys/$name and ~/.ssh/keys/$name.pub"
    else
        echo "Error: ~/.ssh/keys/$name does not exist"
        exit 255
    fi
}

key_list() {
    for key in ~/.ssh/keys/*.pub; do
        [[ -f "$key" ]] || continue
        echo -n "$(basename "$key" .pub) "
        ssh-keygen -lf "$key"
    done
}

# ========== UTILITIES ==========

perms() {
    find ~/.ssh -type d -exec chmod 700 {} +
    find ~/.ssh -type f -exec chmod 600 {} +
    echo "Updated permissions for ~/.ssh"
}

# ========== SSH CONNECTIVITY TEST ==========

test() {
    local test_host=$1
    local delete_failed=false
    local timeout=5

    [[ "$@" =~ --delete-failed ]] && delete_failed=true

    local RED='\033[0;31m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local BLUE='\033[0;34m'
    local NC='\033[0m'

    local total=0 success=0 failed=0 special_success=0 ephemeral_offline=0

    declare -a failed_hosts failed_files ephemeral_offline_hosts

    declare -A special_hosts=(["github.com"]="git_provider")
    local ephemeral_file="$HOME/.ssh/hosts/.ephemeral"
    if [[ -f "$ephemeral_file" ]]; then
        while IFS= read -r line; do
            [[ -z "$line" || "$line" =~ ^# ]] && continue
            special_hosts["$line"]="ephemeral"
        done <"$ephemeral_file"
    fi

    echo "🔍 Testing SSH connectivity in ~/.ssh/hosts/"
    echo "⏱️  Timeout: ${timeout} seconds per host"
    [[ "$delete_failed" == true ]] && echo -e "${RED}🗑️  WARNING: Failed host files will be automatically deleted!${NC}"
    echo ""

    test_single_host() {
        local host_file=$1
        local filename=$(basename "$host_file")

        [[ "$filename" == "config" || "$filename" =~ ^\. ]] && return

        ((total++))

        local host=$(grep -i "^Host" "$host_file" | awk '{print $2}' | head -1)
        local hostname=$(grep -i "^\s*Hostname" "$host_file" | awk '{print $2}' | head -1)
        host=${host:-$filename}

        [[ -z "$host" ]] && return

        local display_info="$host"
        [[ -n "$hostname" ]] && display_info="$host ($hostname)"

        printf "Testing %-40s ... " "$display_info"

        if [[ -n "${special_hosts[$host]}" ]]; then
            local host_type="${special_hosts[$host]}"
            local ssh_output=$(ssh -o BatchMode=yes \
                -o ConnectTimeout="$timeout" \
                -o StrictHostKeyChecking=no \
                -o UserKnownHostsFile=/dev/null \
                "$host" 2>&1 || true)

            if [[ "$ssh_output" =~ "successfully authenticated" ]] ||
                [[ "$ssh_output" =~ "Hi" ]] ||
                [[ "$ssh_output" =~ "Permission denied (publickey)" ]]; then
                echo -e "${BLUE}✅ OK ($host_type)${NC}"
                ((success++))
                ((special_success++))
            else
                if [[ "$host_type" == "ephemeral" ]]; then
                    echo -e "${YELLOW}⏸️  OFFLINE ($host_type)${NC}"
                    ephemeral_offline_hosts+=("$([ -n "$hostname" ] && echo "$filename ($hostname)" || echo "$filename")")
                    ((ephemeral_offline++))
                else
                    echo -e "${RED}❌ FAILED${NC}"
                    failed_hosts+=("$([ -n "$hostname" ] && echo "$filename ($hostname)" || echo "$filename")")
                    failed_files+=("$host_file")
                    ((failed++))
                fi
            fi
        else
            if ssh -o BatchMode=yes \
                -o ConnectTimeout="$timeout" \
                -o StrictHostKeyChecking=no \
                -o UserKnownHostsFile=/dev/null \
                -o LogLevel=ERROR \
                "$host" "true" 2>/dev/null; then
                echo -e "${GREEN}✅ OK${NC}"
                ((success++))
            else
                echo -e "${RED}❌ FAILED${NC}"
                failed_hosts+=("$([ -n "$hostname" ] && echo "$filename ($hostname)" || echo "$filename")")
                failed_files+=("$host_file")
                ((failed++))
            fi
        fi
    }

    if [[ -n "$test_host" && "$test_host" != "--delete-failed" ]]; then
        local host_file="$HOME/.ssh/hosts/$test_host"
        if [[ -f "$host_file" ]]; then
            test_single_host "$host_file"
        else
            echo -e "${RED}❌ Error: Host '$test_host' not found in ~/.ssh/hosts/${NC}"
            return 1
        fi
    else
        for host_file in ~/.ssh/hosts/*; do
            [[ -f "$host_file" ]] && test_single_host "$host_file"
        done
    fi

    if [[ -z "$test_host" || "$test_host" == "--delete-failed" ]]; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "📊 Summary"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "   Total hosts:    $total"
        echo -e "   ${GREEN}Successful:     $success${NC}"
        [[ $special_success -gt 0 ]] && echo -e "   ${BLUE}  ├─ Special:     $special_success${NC}"
        [[ $ephemeral_offline -gt 0 ]] && echo -e "   ${YELLOW}Offline:        $ephemeral_offline (ephemeral)${NC}"
        echo -e "   ${RED}Failed:         $failed${NC}"
        echo ""

        [[ $failed -gt 0 ]] && {
            echo -e "${RED}❌ Failed Hosts:${NC}"
            for host in "${failed_hosts[@]}"; do echo "   - $host"; done
            echo ""
        }

        [[ $ephemeral_offline -gt 0 ]] && {
            echo -e "${YELLOW}⏸️  Offline Ephemeral Hosts:${NC}"
            for host in "${ephemeral_offline_hosts[@]}"; do echo "   - $host"; done
            echo ""
        }

        if [[ "$delete_failed" == true && $failed -gt 0 ]]; then
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo -e "${RED}🗑️  Deleting Failed Host Files${NC}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            for file in "${failed_files[@]}"; do
                local fn=$(basename "$file")
                rm -f "$file" && echo -e "   ${RED}✗${NC} Deleted: $fn" || echo -e "   ${YELLOW}⚠️${NC} Failed to delete: $fn"
            done
            echo ""
            echo -e "${GREEN}✅ Deleted $failed failed host configuration files${NC}"
            echo ""
        fi

        [[ $failed -gt 0 && "$delete_failed" != true ]] && return 1
    fi

    return 0
}

# ========== GIT ==========

pull() {
    cd ~/.sh
    git fetch origin 2>/dev/null || { echo "❌ Failed to fetch from origin"; return 1; }

    local local_head=$(git rev-parse HEAD)
    local remote_head=$(git rev-parse @{u} 2>/dev/null)

    if [[ -z "$remote_head" ]]; then
        echo "⚠️  No upstream tracking branch set"
        return 1
    elif [[ "$local_head" == "$remote_head" ]]; then
        echo "✅ ~/.sh is up to date"
    else
        local behind=$(git rev-list --count HEAD..@{u})
        if [[ $behind -gt 0 ]]; then
            echo "⬇️  $behind new commit(s) available"
            git pull --ff-only || { echo "❌ Pull failed (local changes?) — try: sshm push first"; return 1; }
            echo "✅ ~/.sh updated"
        else
            echo "ℹ️  Local is ahead of upstream — use: sshm push"
        fi
    fi
}

push() {
    cd ~/.sh
    local status=$(git status --porcelain)

    if [[ -z "$status" ]]; then
        # Nothing to commit — but maybe we need to push existing commits
        local ahead=$(git rev-list --count @{u}..HEAD 2>/dev/null)
        if [[ $ahead -gt 0 ]]; then
            echo "⬆️  Pushing $ahead commit(s)..."
            git push || { echo "❌ Push failed"; return 1; }
            echo "✅ Pushed to origin"
        else
            echo "✅ Nothing to commit, up to date with origin"
        fi
        return 0
    fi

    # Build commit message
    local msg
    if [[ -n "$1" ]]; then
        msg="$*"
    else
        msg="Update: $(echo "$status" | awk '{print $2}' | tr '\n' ' ')"
    fi

    git add -A
    git commit -m "$msg"
    git push || { echo "❌ Push failed"; return 1; }
    echo "✅ Committed and pushed"
}

# ========== SSHD SERVICE ==========

start() {
    sudo systemctl start sshd
    echo "SSH daemon started (not enabled at boot)"
}

stop() {
    sudo systemctl stop sshd
    sudo systemctl disable sshd
    sudo pkill -9 sshd 2>/dev/null || true
    echo "SSH daemon stopped, disabled, and all connections dropped"
}

# ========== COMMAND HANDLER ==========

cmd=$1
shift
case $cmd in
i | init) init ;;
s | sync) sync "$@" ;;
c | create) create "$@" ;;
r | read | show) show "$@" ;;
u | update) update "$@" ;;
d | delete) delete "$@" ;;
l | list) list ;;
t | test) test "$@" ;;
kc | key_create) key_create "$@" ;;
kr | key_read) key_read "$@" ;;
kd | key_delete) key_delete "$@" ;;
kl | key_list) key_list ;;
p | perms) perms ;;
pull) pull ;;
push) push "$@" ;;
start) start ;;
stop) stop ;;
h | help) help "$@" ;;
ha) help all ;;
*) echo "Unknown command '$cmd'" >&2; help >&2; exit 1 ;;
esac

exit 0
