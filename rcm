# RC Manager - Manages ~/.rc runtime configuration directory
# Source shell environment
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[[ -f "$DIR/_shrc" ]] && source "$DIR/_shrc"


# Help function
help() {
    case $1 in
    i | init)
        echo "Initialize shell configuration"
        echo "Usage: rcm init"
        echo "  - Creates ~/.bash_profile from template if missing"
        echo "  - Creates ~/.bashrc from template if missing"
        echo "  - Creates ~/.myrc from template if missing"
        ;;
    s | sync)
        echo "Sync ~/.rc directory to remote host"
        echo "Usage: rcm sync <ssh_host>"
        echo "Example: rcm sync myserver"
        echo "Note: ~/.myrc is not synced (machine-local only)"
        ;;
    *)
        echo "Usage: rcm <cmd> [args]"
        echo "Commands: init, sync, help"
        echo ""
        echo "For SSH management use: sshm"
        ;;
    esac
}

[[ -z $1 || $1 =~ -h ]] && help && exit 1

# Initialize RC structure
init() {
    # Create ~/.bash_profile from template if missing
    if [[ ! -f ~/.bash_profile ]]; then
        if [[ -f ~/.rc/_bash_profile ]]; then
            cp ~/.rc/_bash_profile ~/.bash_profile
            echo "✅ Created ~/.bash_profile"
        else
            echo "⚠️  Template ~/.rc/_bash_profile not found"
        fi
    else
        echo "ℹ️  ~/.bash_profile already exists"
    fi

    # Create ~/.bashrc from template if missing
    if [[ ! -f ~/.bashrc ]]; then
        if [[ -f ~/.rc/_bashrc ]]; then
            cp ~/.rc/_bashrc ~/.bashrc
            echo "✅ Created ~/.bashrc"
        else
            echo "⚠️  Template ~/.rc/_bashrc not found"
        fi
    else
        # Ensure existing .bashrc sources ~/.rc/_shrc
        local source_line='[[ -f ~/.rc/_shrc ]] && source ~/.rc/_shrc'
        if ! grep -qF "$source_line" ~/.bashrc; then
            echo "" >> ~/.bashrc
            echo "# Source RC shell enhancements" >> ~/.bashrc
            echo "$source_line" >> ~/.bashrc
            echo "✅ Added sourcing line to ~/.bashrc"
        else
            echo "ℹ️  ~/.bashrc already sources ~/.rc/_shrc"
        fi
    fi

    # Create user customization file from template if missing
    if [[ ! -f ~/.myrc ]]; then
        if [[ -f ~/.rc/_myrc.example ]]; then
            cp ~/.rc/_myrc.example ~/.myrc
            echo "✅ Created ~/.myrc from template"
            echo "ℹ️  Edit ~/.myrc to add your personal customizations"
        else
            echo "⚠️  Template ~/.rc/_myrc.example not found"
        fi
    else
        echo "ℹ️  ~/.myrc already exists"
    fi

    echo "✅ RC structure initialized"
}

# Sync ~/.rc directory to remote host
sync() {
    local ssh_host="$1"

    if [[ -z "$ssh_host" ]]; then
        echo "❌ Error: SSH host required"
        echo "Usage: rcm sync <ssh_host>"
        exit 1
    fi

    # Check if SSH host exists in config
    if ! grep -q "^Host $ssh_host$" ~/.ssh/hosts/* 2>/dev/null; then
        echo "⚠️  Warning: SSH host '$ssh_host' not found in ~/.ssh/hosts/"
        echo "Attempting connection anyway..."
    fi

    echo "🔄 Syncing ~/.rc/ to $ssh_host:~/.rc/..."
    rsync -avz --exclude='.git' ~/.rc/ "$ssh_host":~/.rc/

    if [[ $? -eq 0 ]]; then
        echo "✅ Sync completed"
        echo "🔧 Running init on $ssh_host..."
        ssh "$ssh_host" "~/.rc/rcm init"
    else
        echo "❌ Sync failed"
        exit 1
    fi
}

# Command handler
case $1 in
i | init) init ;;
s | sync) sync $2 ;;
h | help) help $2 ;;
*) echo "Unknown command '$1'" && help ;;
esac

exit 0
